{
  "version": "0.0.1",
  "autoPort": true,
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Next.js Production Preview",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "DB Migration Script",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["run", "migrate"],
      "port": null
    }
  ]
}

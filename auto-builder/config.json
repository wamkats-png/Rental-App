    "nonDestructiveMode": true,
    "backupBeforeWrite": true,
    "softDeleteOnly": true,
    "backupDir": "./backups",
    "archiveDir": "./archive",
    "logDir": "./logs"
  },
  "appContext": {
    "domain": "Property management — Uganda",
    "currency": "UGX",
    "currencyStorage": "integers_only",
    "fiscalYear": "July_to_June",

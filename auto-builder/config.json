      "individual": "12%",
      "company": "30%"
    },
    "payments": ["MTN Mobile Money", "Airtel Money"],
    "sms": "Africa's Talking",
    "targetUsers": "Ugandan landlords and property managers",
    "primaryDevice": "mobile"
  },
  "stack": {
    "frontend": "Next.js 14.1 (App Router)",
    "language": "TypeScript (strict)",
    "database": "Supabase (PostgreSQL + Auth + Storage)",
    "styling": "TailwindCSS",
    "ai": "Anthropic Claude API",
    "deployment": "Vercel",
    "forms": "React Hook Form + Zod",
    "state": "Zustand",
    "charts": "Recharts",
    "pdf": "jsPDF",
    "dates": "date-fns",
    "smsProvider": "Africa's Talking",
    "emailProvider": "Resend"
  },
